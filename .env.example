# Backend - Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Backend - Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Frontend - API URL (optional)
